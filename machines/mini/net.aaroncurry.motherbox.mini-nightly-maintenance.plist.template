<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>net.aaroncurry.motherbox.mini-nightly-maintenance</string>

	<key>ProgramArguments</key>
	<array>
		<string>__MINI_SH__</string>
		<string>maintain</string>
		<string>nightly</string>
	</array>

	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>__HOME__/.asdf/shims:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:__HOME__/.config/motherbox/bin:__HOME__/.local/bin</string>
	</dict>

	<key>StartCalendarInterval</key>
	<dict>
		<key>Hour</key>
		<integer>2</integer>
		<key>Minute</key>
		<integer>0</integer>
	</dict>

	<key>StandardOutPath</key>
	<string>__HOME__/.config/motherbox/logs/mini-nightly-maintenance.log</string>
	<key>StandardErrorPath</key>
	<string>__HOME__/.config/motherbox/logs/mini-nightly-maintenance.log</string>
</dict>
</plist>
