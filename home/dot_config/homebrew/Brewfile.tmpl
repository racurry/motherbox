#
# This is the `brew bundle --global` 
#   
# Intentionally not using https://www.chezmoi.io/user-guide/advanced/install-packages-declaratively/
# This lets `brew bundle check/cleanup/list/edit --global` behave as expected
#
# LAYERING RULE: language-ecosystem CLIs that drag a runtime do NOT belong here.
# They live with their package manager — Python tools in uv (setup-stuff/uv),
# Node tools in pnpm. Only standalone binaries (incl. ruff, biome) stay in brew.

# --- Runtime managers (Layer 1 seeds Layer 2) ---
brew "mise"

# --- Shell & core CLI ---
brew "chezmoi"
brew "direnv"
brew "fzf"
brew "jq"
brew "mas"
brew "pure"
brew "zsh"
brew "zsh-autosuggestions"
brew "zsh-syntax-highlighting"

