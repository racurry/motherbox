{{- $machine := index . "machine" | default "" -}}
# SSH client configuration

Include ~/.orbstack/ssh/config
Include ~/.colima/ssh_config

{{ if eq $machine "mini" }}
# GitHub: use the local mini key, not the 1Password agent. This block must come
# before the Host * agent block so that "IdentityAgent none" wins (ssh uses the
# first value obtained per host). The private key must already exist on the
# machine; it is not exported from 1Password.
Host github.com
    HostName github.com
    User git
    IdentitiesOnly yes
    IdentityFile ~/.ssh/id_ed25519_mini
    IdentityAgent none
    UseKeychain yes
{{- end }}

# 1Password SSH Agent
Host *
    IdentityAgent ~/.1password/agent.sock
