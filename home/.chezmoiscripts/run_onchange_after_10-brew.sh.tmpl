#!/bin/bash
# Layer 1 — Homebrew bundle.
#
# Run by chezmoi during `chezmoi apply`. The managed global Brewfile lives at
# ~/.config/homebrew/Brewfile (source: dot_config/homebrew/Brewfile.tmpl). The
# hash line below ties this run_onchange script to that Brewfile's source, so
# `brew bundle` only re-runs when the Brewfile changes. Layer order is encoded
# in the filename prefix (10-brew before 20-mise, ...).
#
# Brewfile source hash: {{ include "dot_config/homebrew/Brewfile.tmpl" | sha256sum }}
set -euo pipefail

# brew may not be on PATH if apply runs outside an interactive shell.
if ! command -v brew >/dev/null 2>&1; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Bundle the managed global Brewfile by explicit path. This runs under
# `chezmoi apply` (not an interactive shell), so it can't rely on XDG_CONFIG_HOME
# being set; by-hand `brew bundle --global` resolves to this same file via
# XDG_CONFIG_HOME from .zshrc.
BREWFILE="${HOME}/.config/homebrew/Brewfile"

# Mac App Store apps need an interactive, signed-in App Store session, so they
# can't install headless. When unattended (UNATTENDED is exported by ping), skip
# every `mas` entry by id — otherwise brew bundle aborts the whole bundle on the
# failed installs. HOMEBREW_BUNDLE_MAS_SKIP matches by name or id.
if [[ "${UNATTENDED:-false}" == "true" ]]; then
    mas_ids="$(grep '^mas ' "${BREWFILE}" | sed -E 's/.*id: *//')"
    if [[ -n "${mas_ids}" ]]; then
        export HOMEBREW_BUNDLE_MAS_SKIP="${mas_ids//$'\n'/ }"
        echo "==> Unattended: skipping Mac App Store apps"
    fi
fi

echo "==> Layer 1: brew bundle"
brew bundle --file="${BREWFILE}"
