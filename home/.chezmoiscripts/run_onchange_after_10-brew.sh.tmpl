#!/bin/bash

# Rendered-Brewfile hash (fires on any *.Brewfile part or profile/machine change):
# {{ includeTemplate "dot_config/homebrew/Brewfile.tmpl" . | sha256sum }}
set -euo pipefail

# Thin hook: the real logic lives in scripts/apps/brew/bundle.sh so it can
# also be run by hand. This wrapper only decides chezmoi policy: a partial
# `brew bundle` failure (flaky download, upstream-broken cask, an MAS app that
# needs a human) must not abort `chezmoi apply` and take the remaining scripts
# (mise, folders, launchagents, macOS defaults) down with it. Report loudly
# and keep going; fix the offenders and re-run the script by hand (or
# `mother setup -f`).
BUNDLE="$CHEZMOI_WORKING_TREE/scripts/apps/brew/bundle.sh"

echo "==> Layer 1: brew bundle"
if ! "$BUNDLE"; then
    echo "WARNING: brew bundle reported failures above; continuing setup." >&2
    echo "         Fix them, then re-run: $BUNDLE" >&2
fi
