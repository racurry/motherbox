#!/bin/bash
# mother — run the machine.  responsible for coordinating any bits across
#          the repo that need coordination.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

: "${UNATTENDED:=false}"

show_help() {
    cat <<EOF
Usage: $(basename "$0") [COMMAND] [OPTIONS]

COMMANDS:
  setup             Run all the things to set up a machine
  help              You know what help is

OPTIONS:
  -u                Skip operations requiring human interaction

Profile and machine are persisted by chezmoi (~/.config/chezmoi/chezmoi.toml).
EOF
}

# ==========================================================================
# Setup - install homebrew + chezmoi.  
#         chezmoi apply handles almost everything else
#         run any other scripts that chezmoi can't handle cleanly
# ==========================================================================


do_setup() {
    cd "${REPO_ROOT}"

    printf "Checking Homebrew\n"
    if ! command -v brew >/dev/null 2>&1; then
        # No homebrew on the path
        logger -t motherbox -p user.notice "motherbox: Homebrew not found on path"

        if [[ ! -x /opt/homebrew/bin/brew ]]; then
            # Homebrew is not installed at all; install it.
            logger -t motherbox -p user.notice "motherbox: Homebrew not installed at all"
            /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        fi

        logger -t motherbox -p user.notice "motherbox: homebrew installed, add to path"
        eval "$(/opt/homebrew/bin/brew shellenv)"
    fi

    printf "Checking chezmoi\n"
    if ! command -v chezmoi >/dev/null 2>&1; then
        logger -t motherbox -p user.notice "motherbox: no chezmoi, installing with Homebrew"
        brew install chezmoi
    fi

    chezmoi init --source="${REPO_ROOT}/home"
    # chezmoi apply

    if [[ "$UNATTENDED" != "true" ]]; then
        printf "Setting up things that need sudo access...\n"
        "${REPO_ROOT}/scripts/utils/macos_prefs_sudo.sh"
    fi
}

# ==========================================================================
# Main — parse options, then dispatch on subcommand.  Options may appear in
#        any position; the first non-option argument is the command.
# ==========================================================================

COMMAND=""
for arg in "$@"; do
    case "$arg" in
    -h)
        show_help
        exit 0
        ;;
    -u) UNATTENDED=true ;;
    -*)
        printf "Unknown option: %s\n\n" "$arg" >&2
        show_help
        exit 1
        ;;
    *) COMMAND="${COMMAND:-$arg}" ;;
    esac
done

case "$COMMAND" in
setup)
    do_setup
    ;;
help)
    show_help
    ;;
"")
    printf "No command given.\n\n" >&2
    show_help
    exit 1
    ;;
*)
    printf "Unknown command: %s\n\n" "$COMMAND" >&2
    show_help
    exit 1
    ;;
esac
