#!/bin/bash
# mother — set up this machine, layer by layer (bottom to top).
#
# mother owns bootstrap and any interactive/privileged steps. The per-layer
# installs (Homebrew bundle, mise runtimes, etc.) are change-driven chezmoi
# run_onchange hooks under home/.chezmoiscripts/, executed by `chezmoi apply`.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="${SCRIPT_DIR}"

ORIGINAL_ARGS=("$@")

export LOG_TAG="mother"
: "${DRY_RUN:=false}"

# ==========================================================================
# Helpers — self-contained; only the pieces mother actually uses.
# ==========================================================================

# Mother Box config paths
XDG_CFG_HOME="${XDG_CONFIG_HOME:-${HOME}/.config}"
PATH_MOTHERBOX_CONFIG="${XDG_CFG_HOME}/motherbox"
PATH_MOTHERBOX_CONFIG_FILE="${PATH_MOTHERBOX_CONFIG}/config"

: "${UNATTENDED:=false}"

# Color codes for readability.
CLR_RESET=$'\033[0m'    # reset / default
CLR_INFO=$'\033[1;34m'  # bright blue for informational messages
CLR_WARN=$'\033[1;33m'  # bright yellow for warnings
CLR_ERROR=$'\033[1;31m' # bright red for errors

# _log_emit sends a line to the macOS unified log via syslog. The OS owns
# retention and rotation (auto-pruned), so there is no file to grow or clean
# up. This logger can't set an os_log subsystem (BSD build: -t/-p only) and the
# tag is dropped in `log show`, so we prefix the message with "mother:" to make
# our lines filterable. View with:
#   log show --predicate 'eventMessage BEGINSWITH "mother:"' --last 1h
_log_emit() {
    logger -t mother -p user.notice "mother: $*"
}

log_info() {
    printf "%s[%s] %s%s\n" "${CLR_INFO}" "${LOG_TAG}" "$*" "${CLR_RESET}"
    _log_emit "[INFO] $*"
}

log_warn() {
    printf "%s[%s] %s%s\n" "${CLR_WARN}" "${LOG_TAG}" "$*" "${CLR_RESET}" >&2
    _log_emit "[WARN] $*"
}

log_error() {
    printf "%s[%s] %s%s\n" "${CLR_ERROR}" "${LOG_TAG}" "$*" "${CLR_RESET}" >&2
    _log_emit "[ERROR] $*"
}

fail() {
    log_error "$*"
    exit 1
}

print_heading() {
    local text="$1"
    printf "\n\033[1;36m==> %s\033[0m\n" "$text"
    _log_emit "==> $text"
}

require_command() {
    local cmd="$1"
    if ! command -v "$cmd" >/dev/null 2>&1; then
        fail "Required command '$cmd' not found in PATH"
    fi
}

# _config_defaults returns default config values as shell assignments.
_config_defaults() {
    cat <<'EOF'
BACKUP_RETENTION_DAYS=60
PROFILE=
MACHINE=
EOF
}

# ensure_config creates the config file with defaults if it doesn't exist.
ensure_config() {
    if [[ -f "${PATH_MOTHERBOX_CONFIG_FILE}" ]]; then
        return 0
    fi

    mkdir -p "${PATH_MOTHERBOX_CONFIG}"
    _config_defaults >"${PATH_MOTHERBOX_CONFIG_FILE}"
}

# get_config retrieves a configuration value via stdout.
get_config() {
    local key="$1"

    ensure_config

    (
        # shellcheck source=/dev/null
        source "${PATH_MOTHERBOX_CONFIG_FILE}"
        eval "echo \"\${${key}:-}\""
    )
}

# set_config sets a configuration value, creating the config file if needed.
set_config() {
    local key="$1"
    local value="$2"

    ensure_config

    local tmp_file
    tmp_file="$(mktemp)"

    if grep -q "^${key}=" "${PATH_MOTHERBOX_CONFIG_FILE}"; then
        sed "s|^${key}=.*|${key}=${value}|" "${PATH_MOTHERBOX_CONFIG_FILE}" >"${tmp_file}"
    else
        cat "${PATH_MOTHERBOX_CONFIG_FILE}" >"${tmp_file}"
        echo "${key}=${value}" >>"${tmp_file}"
    fi

    mv "${tmp_file}" "${PATH_MOTHERBOX_CONFIG_FILE}"
}

# prompt_profile prompts interactively for setup mode. Sets PROFILE.
prompt_profile() {
    print_heading "Setup Mode Selection"
    echo "Please select your setup mode:"
    echo "  1) firsthand - Install Firsthand work-specific tools & settings"
    echo "  2) personal  - Install personal-specific tools & settings"
    echo ""

    while true; do
        read -rp "Enter your choice (1 or 2): " choice
        case $choice in
        1 | firsthand)
            PROFILE="firsthand"
            break
            ;;
        2 | personal)
            PROFILE="personal"
            break
            ;;
        *)
            echo "Invalid choice. Please enter 1 (firsthand) or 2 (personal)"
            ;;
        esac
    done
}

# determine_profile resolves setup mode from flags, config, or prompt.
# Sets PROFILE and persists to config. Precedence: --profile > config > prompt.
# Ignores unrecognized arguments, so callers can pass "$@" directly.
determine_profile() {
    local reset_mode=false
    local unattended=false
    local mode_override=""

    while [[ $# -gt 0 ]]; do
        case $1 in
        --reset | --reset-profile)
            reset_mode=true
            shift
            ;;
        --unattended)
            unattended=true
            shift
            ;;
        --profile)
            mode_override="${2:-}"
            shift 2
            ;;
        *) shift ;;
        esac
    done

    if [[ -n "${mode_override}" ]]; then
        PROFILE="${mode_override}"
    elif [[ "${reset_mode}" != "true" ]]; then
        PROFILE="$(get_config PROFILE)"
    fi

    if [[ -z "${PROFILE:-}" ]]; then
        if [[ "${unattended}" == "true" ]]; then
            log_error "Setup mode not set and --unattended prevents prompting"
            log_info "Use --profile personal or --profile firsthand to set mode"
            return 1
        fi
        prompt_profile
    fi

    set_config PROFILE "${PROFILE}"
    log_info "Setup mode: ${PROFILE}"
    return 0
}

# determine_machine resolves machine name from flags or config.
# Sets MACHINE and persists to config. Machine is optional.
determine_machine() {
    local machine_override=""

    while [[ $# -gt 0 ]]; do
        case $1 in
        --machine)
            machine_override="${2:-}"
            shift 2
            ;;
        *) shift ;;
        esac
    done

    if [[ -n "${machine_override}" ]]; then
        MACHINE="${machine_override}"
    else
        MACHINE="$(get_config MACHINE)"
    fi

    if [[ -n "${MACHINE}" ]]; then
        set_config MACHINE "${MACHINE}"
        log_info "Machine: ${MACHINE}"
    fi
}

show_help() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Set up this machine layer by layer:

  Bootstrap   Install Homebrew + chezmoi + 1Password CLI (the minimum needed
              to run everything else).
  Layers      \`chezmoi apply\` runs the change-driven layer hooks:
                L1  Homebrew host tools & applications
                L2  mise runtimes              (todo)
                L3  uv / pnpm / cargo packages (todo)
  Interactive Privileged / interactive steps that should NOT fire on every
              \`chezmoi apply\` (macOS defaults, Mac App Store, TCC).  (todo)

OPTIONS:
  --profile PROFILE   Set profile (personal, firsthand, ...)
  --machine MACHINE   Set machine (e.g. mini) for machine-specific setup
  --reset-profile     Ignore saved profile and prompt for selection
  --unattended        Skip operations requiring human interaction
  --dry-run           Preview only: no installs, no config writes; shows what
                      \`chezmoi apply\` would change (run scripts are not executed)
  -h, --help          Show this help message and exit

Configuration is persisted to ~/.config/motherbox/config.
EOF
}

for arg in "$@"; do
    case $arg in
    -h | --help)
        show_help
        exit 0
        ;;
    --unattended) export UNATTENDED=true ;;
    --dry-run) DRY_RUN=true ;;
    esac
done

# ==========================================================================
# Bootstrap — the minimum needed before chezmoi can drive the layers.
# ==========================================================================

ensure_homebrew() {
    if command -v brew >/dev/null 2>&1; then
        log_info "Homebrew present"
        return 0
    fi

    if [[ -x /opt/homebrew/bin/brew ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
        log_info "Homebrew installed; sourced into this shell"
        return 0
    fi

    if [[ "${DRY_RUN}" == "true" ]]; then
        log_info "[dry-run] would install Homebrew"
        return 0
    fi

    require_command curl
    log_info "Installing Homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
}

ensure_bootstrap_tools() {
    # chezmoi drives the layers; the 1Password CLI resolves secret templates
    # during `chezmoi apply`. Both must exist before we apply.
    if [[ "${DRY_RUN}" == "true" ]]; then
        command -v chezmoi >/dev/null 2>&1 || log_info "[dry-run] would: brew install chezmoi"
        command -v op >/dev/null 2>&1 || log_info "[dry-run] would: brew install --cask 1password-cli"
        return 0
    fi
    command -v chezmoi >/dev/null 2>&1 || brew install chezmoi
    command -v op >/dev/null 2>&1 || brew install --cask 1password-cli
}

configure_chezmoi() {
    require_command chezmoi
    # Pass the resolved profile/machine so promptStringOnce doesn't re-prompt.
    chezmoi init --source="${REPO_ROOT}/home" \
        --promptString "profile=${PROFILE}" \
        --promptString "machine=${MACHINE:-}"
    log_info "chezmoi configured (profile: ${PROFILE}, machine: ${MACHINE:-none})"
}

# ==========================================================================
# Main
# ==========================================================================

if [[ $EUID -eq 0 ]]; then
    fail "Run mother as a regular user, not root"
fi

if [[ "$(pwd)" != "${REPO_ROOT}" ]]; then
    cd "${REPO_ROOT}"
fi

determine_profile ${ORIGINAL_ARGS[@]+"${ORIGINAL_ARGS[@]}"} || exit 1
determine_machine ${ORIGINAL_ARGS[@]+"${ORIGINAL_ARGS[@]}"}

print_heading "Bootstrap"
ensure_homebrew
ensure_bootstrap_tools
if [[ "${DRY_RUN}" != "true" ]]; then
    configure_chezmoi
fi

print_heading "Layers"
# chezmoi apply runs the run_onchange layer hooks (L1 brew today) and applies
# dotfiles. Hooks only re-run when their inputs change.
if [[ "${DRY_RUN}" == "true" ]]; then
    if command -v chezmoi >/dev/null 2>&1; then
        log_info "[dry-run] previewing chezmoi apply (no mutations; run scripts are not executed)"
        chezmoi apply --source="${REPO_ROOT}/home" --dry-run --verbose
    else
        log_warn "[dry-run] chezmoi not installed; cannot preview apply"
    fi
else
    chezmoi apply
fi

print_heading "Interactive / privileged"
# macOS defaults (incl. one sudo write) plus Dock/Finder restarts. These live in
# libexec/ — invoked by mother, never on $PATH — and run here, outside chezmoi, so
# a routine `chezmoi apply` never triggers password prompts or UI restarts. The
# script's sudo step self-skips under --unattended.
# Mac App Store apps install as part of L1 (mas entries in the Brewfile); the
# only manual prerequisite is signing in to App Store.app (mas 7.x has no CLI
# sign-in). The L1 hook skips mas entirely when --unattended.
# TODO: TCC signing belongs in this phase too (libexec/).
macos_args=(setup)
[[ "${UNATTENDED:-false}" == "true" ]] && macos_args+=(--unattended)
if [[ "${DRY_RUN}" == "true" ]]; then
    log_info "[dry-run] would run: libexec/macos.sh ${macos_args[*]}"
else
    "${REPO_ROOT}/libexec/macos.sh" "${macos_args[@]}"
fi

print_heading "Done"
