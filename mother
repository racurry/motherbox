#!/bin/bash
# mother — run the machine.  responsible for coordinating any bits across
#          the repo that need coordination.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

: "${UNATTENDED:=false}"
: "${FORCE_BREW_BUNDLE:=false}"

SUDO_KEEPALIVE_PID=""

# Askpass helper scoped to the Homebrew steps below. brew adds `sudo -A` when
# SUDO_ASKPASS is set, so its per-cask sudo pulls from 1Password instead of a
# Touch ID prompt per cask. Everything else keeps using the up-front sudo
# timestamp / pam_tid. chezmoi deploys this helper with the profile's correct
# 1Password vault ref baked in.
SUDO_ASKPASS_HELPER="${HOME}/.config/motherbox/sudo_askpass_1password.sh"

show_help() {
    cat <<EOF
Usage: $(basename "$0") [COMMAND] [OPTIONS]

COMMANDS:
  setup             Run all the things to set up a machine
  help              You know what help is

OPTIONS:
  -f                Run brew bundle explicitly after chezmoi apply
  -u                Skip operations requiring human interaction

Profile and machine are persisted by chezmoi (~/.config/chezmoi/chezmoi.toml).
EOF
}

# ==========================================================================
# Setup - install homebrew + chezmoi.  
#         chezmoi apply handles almost everything else
#         run any other scripts that chezmoi can't handle cleanly
# ==========================================================================


do_setup() {
    cd -- "${REPO_ROOT}" || exit 1

    start_sudo_session

    trap stop_sudo_session EXIT
    trap 'exit 129' HUP
    trap 'exit 130' INT
    trap 'exit 143' TERM

    # Enable Touch ID for sudo so the rest of setup (and future runs)
    # authenticate with a fingerprint tap instead of a password.
    "${REPO_ROOT}/scripts/utils/sudo_touchid.sh"

    # Apply root-only macOS preferences while the sudo timestamp is fresh.
    "${REPO_ROOT}/scripts/utils/macos_prefs.sh"

    printf "Checking Homebrew\n"
    if ! command -v brew >/dev/null 2>&1; then
        # No homebrew on the path
        logger -t motherbox -p user.notice "motherbox: Homebrew not found on path"

        if [[ ! -x /opt/homebrew/bin/brew ]]; then
            # Homebrew is not installed at all; install it.
            logger -t motherbox -p user.notice "motherbox: Homebrew not installed at all"
            /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        fi

        logger -t motherbox -p user.notice "motherbox: homebrew installed, add to path"
        eval "$(/opt/homebrew/bin/brew shellenv)"
    fi

    printf "Checking chezmoi\n"
    if ! command -v chezmoi >/dev/null 2>&1; then
        logger -t motherbox -p user.notice "motherbox: no chezmoi, installing with Homebrew"
        brew install chezmoi
    fi

    printf "Applying chezmoi...\n"
    chezmoi init --source="${REPO_ROOT}/home"
    # chezmoi runs the Homebrew bundle; give brew the askpass so its per-cask
    # sudo uses 1Password instead of a Touch ID prompt per cask.
    SUDO_ASKPASS="$SUDO_ASKPASS_HELPER" chezmoi apply
    run_forced_brew_bundle

     # re-apply to skip the interactive bits
    printf "Setup complete!\n"
}

# ==========================================================================
# Sudo session — authenticate once up front and keep the timestamp fresh so
# scripts run during setup can call sudo without re-authenticating. With Touch
# ID for sudo enabled (auth sufficient pam_tid.so in /etc/pam.d/sudo_local),
# the initial prompt is a fingerprint tap and nested sudo calls fall through to
# the cached timestamp.
# ==========================================================================

start_sudo_session() {
    printf "Opening sudo session\n"
    /usr/bin/sudo -v || exit 1

    while sleep 30; do
        /usr/bin/sudo -n -v >/dev/null 2>&1 || exit 0
    done &
    SUDO_KEEPALIVE_PID=$!
}

stop_sudo_session() {
    [[ -n "${SUDO_KEEPALIVE_PID:-}" ]] || return 0
    kill "$SUDO_KEEPALIVE_PID" 2>/dev/null || :
    wait "$SUDO_KEEPALIVE_PID" 2>/dev/null || :
}

run_forced_brew_bundle() {
    [[ "$FORCE_BREW_BUNDLE" == "true" ]] || return 0

    local brewfile="${HOME}/.config/homebrew/Brewfile"
    if [[ ! -f "$brewfile" ]]; then
        printf "Brewfile not found: %s\n" "$brewfile" >&2
        exit 1
    fi

    printf "Running brew bundle explicitly\n"
    SUDO_ASKPASS="$SUDO_ASKPASS_HELPER" brew bundle --file="$brewfile"
}

# ==========================================================================
# Main — parse options, then dispatch on subcommand.  Options may appear in
#        any position; the first non-option argument is the command.
# ==========================================================================

COMMAND=""
for arg in "$@"; do
    case "$arg" in
    -h)
        show_help
        exit 0
        ;;
    -f) FORCE_BREW_BUNDLE=true ;;
    -u) UNATTENDED=true ;;
    -*)
        printf "Unknown option: %s\n\n" "$arg" >&2
        show_help
        exit 1
        ;;
    *) COMMAND="${COMMAND:-$arg}" ;;
    esac
done

case "$COMMAND" in
setup)
    do_setup
    ;;
help)
    show_help
    ;;
"")
    printf "No command given.\n\n" >&2
    show_help
    exit 1
    ;;
*)
    printf "Unknown command: %s\n\n" "$COMMAND" >&2
    show_help
    exit 1
    ;;
esac
