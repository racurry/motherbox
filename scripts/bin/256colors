#!/usr/bin/env bash
# Print all 256 terminal colors with numbers, names, and sample glyphs.

# Standard color names (0-15)
names=(
  black red green yellow blue magenta cyan white
  bright_black bright_red bright_green bright_yellow
  bright_blue bright_magenta bright_cyan bright_white
)

sample="AaBb ▓▓░░ ●○ ↑↓ ⚠ │"

printf "\n── Standard Colors (0-15) ──\n\n"
for i in {0..15}; do
  printf "\033[38;5;%sm%-3s %-16s %s\033[0m\n" "$i" "$i" "${names[$i]}" "$sample"
done

printf "\n── 216-Color Cube (16-231) ──\n\n"
for i in $(seq 16 231); do
  printf "\033[38;5;%sm%-4s %s\033[0m" "$i" "$i" "$sample"
  # 6 per row (one row per hue step)
  col=$(( (i - 16) % 6 ))
  if [ "$col" -eq 5 ]; then
    printf "\n"
  else
    printf "  "
  fi
done

printf "\n\n── Grayscale (232-255) ──\n\n"
for i in $(seq 232 255); do
  printf "\033[38;5;%sm%-4s %s\033[0m\n" "$i" "$i" "$sample"
done

printf "\n"
