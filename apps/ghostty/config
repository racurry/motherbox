# Ghostty Terminal Configuration
# https://ghostty.org/docs/config/reference


##### FONTS #####

font-family = FiraCode Nerd Font Mono
font-size = 17


##### WINDOW #####

background-opacity = 0.95
confirm-close-surface = false
working-directory = home
window-padding-x = 4
window-padding-y = 4


##### macOS SPECIFIC #####

macos-option-as-alt = left
macos-titlebar-style = tabs


##### SHELL INTEGRATION #####

# Automatic shell integration (zsh, bash, fish, elvish)
shell-integration = detect


##### KEY BINDINGS #####

keybind = cmd+shift+backslash=new_split:right
keybind = cmd+shift+minus=new_split:down


##### THEME #####

# Built-in theme (Ghostty includes many themes)
# Use `ghostty +list-themes` to see available themes
theme = Catppuccin Mocha
